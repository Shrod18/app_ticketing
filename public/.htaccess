<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /app-ticketing/public/
    
    # Ne pas rewriter les fichiers/dossiers réels
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Rediriger vers index.php
    RewriteRule ^(.*)$ index.php?$1 [QSA,L]
</IfModule>

# Sécurité
<FilesMatch "\.(php|phtml|php3|php4|php5|php6|php7|phps|pht|phar|phpt)$">
    Deny from all
</FilesMatch>

# Empêcher l'accès aux fichiers sensibles
<Files ~ "\.(env|sql|json)$">
    Deny from all
</Files>

# Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml application/javascript text/css
</IfModule>
